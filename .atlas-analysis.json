  "keyFeatures": [
    "Transactional email sending via REST API with template support and variable substitution",
    "Email campaigns with audience segmentation and scheduling",
    "Automated workflow builder with triggers, delays, conditions, and webhook steps",
    "Contact management with custom data fields and dynamic/static segments",
    "Real-time analytics for opens, clicks, bounces, and engagement",
    "Custom domain verification with DKIM, SPF, and MX record support",
    "Built-in event tracking system for triggering automations",
    "SMTP relay server for sending emails via standard SMTP protocol",
    "Self-hostable via Docker with AWS SES backend",
    "Inbound email reception and processing"
  ],
  "publicApiSurface": [
    "POST /v1/send — Send transactional email(s)",
    "POST /v1/track — Track event for a contact",
    "GET /contacts — List contacts",
    "POST /contacts — Create contact",
    "GET /contacts/:id — Get contact",
    "PATCH /contacts/:id — Update contact",
    "DELETE /contacts/:id — Delete contact",
    "GET /templates — List templates",
    "POST /templates — Create template",
    "GET /campaigns — List campaigns",
    "POST /campaigns — Create campaign",
    "POST /campaigns/:id/send — Send or schedule campaign",
    "GET /segments — List segments",
    "POST /segments — Create segment",
    "POST /segments/:id/members — Add contacts to static segment",
    "GET /workflows — List workflows",
    "POST /workflows — Create workflow",
    "GET /events — List events",
    "GET /domains — List domains",
    "POST /domains — Add domain"
  ]
